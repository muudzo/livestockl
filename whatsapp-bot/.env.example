# Copy to .env and fill in. Never commit .env.

# Supabase — grab the service_role key from
# https://supabase.com/dashboard/project/hmeieslclzycyjjjflfh/settings/api
SUPABASE_URL=https://hmeieslclzycyjjjflfh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Where the live app lives (no trailing slash). The bot includes this in the
# "✓ Live! Your listing is up at …" reply so sellers can share the URL.
ZIMLIVESTOCK_PUBLIC_URL=https://app.zimlivestock.com

# Which tenant new WhatsApp-originated listings belong to.
# This must match a slug in public.tenants.
DEFAULT_TENANT_SLUG=zimlivestock-demo

# Optional — defaults are fine for a demo
STORAGE_BUCKET=livestock-images
LISTING_DURATION_DAYS=7
