# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Paynow — Primary payment gateway (Edge Function secrets)
PAYNOW_INTEGRATION_ID=your-integration-id
PAYNOW_INTEGRATION_KEY=your-integration-key
PAYNOW_RESULT_URL=https://your-project.supabase.co/functions/v1/payment-webhook
PAYNOW_RETURN_URL=https://your-domain.com/payment-status

# Stripe — Fallback for card payments / diaspora buyers (Edge Function secrets)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Tawk.to Live Chat (free — get IDs from https://www.tawk.to dashboard)
VITE_TAWKTO_PROPERTY_ID=your-property-id
VITE_TAWKTO_WIDGET_ID=your-widget-id
