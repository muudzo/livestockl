# Copy to .env on the relay machine (Mac mini). Never commit .env.

# REMOTE-API user provisioned by Paynow on usd.txt.co.zw
TXT_USERNAME=remote_<your-handle>
TXT_PASSWORD=<16+ char password issued by Paynow>

# Shared secret for relay → must match TXT_RELAY_SECRET in Supabase.
# Generate with: openssl rand -hex 32
RELAY_SECRET=<32-char random hex>

# Listening port (default 8787; ngrok exposes this)
PORT=8787
